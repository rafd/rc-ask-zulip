# Zulip
ZULIP_SITE=https://recurse.zulipchat.com
ZULIP_API_KEY=

# LLM (defaults target a local Ollama instance)
# For Disco/containers, localhost usually does not have Ollama.
# Set OPENAI_BASE_URL/API_KEY/MODEL to a reachable remote provider instead.
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=ollama
OPENAI_MODEL=llama3.1

# Recurse Center OAuth
# Register an app at https://www.recurse.com/settings/apps
# Set the redirect URI there to match RC_REDIRECT_URI below.
RC_CLIENT_ID=
RC_CLIENT_SECRET=
RC_REDIRECT_URI=http://localhost:8000/auth/callback
# Production example:
# RC_REDIRECT_URI=https://your-app-domain.example.com/auth/callback

# Local only: skip RC login (1 / true / yes). Never enable in production.
# Useful for local development without OAuth credentials.
DEV_AUTH_BYPASS=0

# Random secret used to sign session cookies. Generate with:
#   python -c 'import secrets; print(secrets.token_urlsafe(32))'
SESSION_SECRET=

# Set to "true" in production (HTTPS) so the session cookie is Secure.
SESSION_COOKIE_SECURE=false

# Logging
LOG_LEVEL=INFO
